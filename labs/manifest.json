{
  "version": "0.2.0",
  "description": "Runnable lab manifest — each UC has code you can run locally before using RubberDuck MCP.",
  "setup": {
    "venv": ".venv",
    "install": "pip install -r requirements.txt",
    "index_prompt": "Index my local project at: {repo_path}"
  },
  "labs": {
    "01": {
      "slug": "uc-01-understand-your-code",
      "title": "Understand Your Code",
      "branch": "uc-01-understand-your-code",
      "project_dir": "labs/uc01_understand",
      "start": null,
      "focus_paths": ["demoapp/cmd/build.py", "demoapp/application.py"],
      "verify": "python labs/uc01_understand/verify.py"
    },
    "02": {
      "slug": "uc-02-codebase-audit",
      "title": "Codebase Audit",
      "branch": "uc-02-codebase-audit",
      "project_dir": "labs/uc02_security_lab",
      "start": "uvicorn demoapp.api.server:app --host 127.0.0.1 --port 8080",
      "url": "http://127.0.0.1:8080/docs",
      "focus_paths": ["demoapp/config.py", "demoapp/api/server.py"],
      "verify": "python labs/uc02_security_lab/verify.py"
    },
    "03": {
      "slug": "uc-03-localize-and-fix-bugs",
      "title": "Localize and Fix Bugs",
      "branch": "uc-03-localize-and-fix-bugs",
      "project_dir": "labs/uc03_buggy_orm",
      "start": null,
      "focus_paths": ["demoapp/db/query.py"],
      "verify": "pytest labs/uc03_buggy_orm/tests -q"
    },
    "04": {
      "slug": "uc-04-code-review",
      "title": "Code Review",
      "branch": "uc-04-code-review",
      "project_dir": "labs/uc04_pr_review",
      "start": null,
      "focus_paths": ["demoapp/db/query.py", "fixtures/uc-04-pr-order-by-diff.md"],
      "verify": "python labs/uc04_pr_review/verify.py"
    },
    "05": {
      "slug": "uc-05-change-impact-analysis",
      "title": "Change Impact Analysis",
      "branch": "uc-05-change-impact-analysis",
      "project_dir": "labs/uc05_impact",
      "start": null,
      "focus_paths": ["demoapp/config.py", "labs/uc05_impact/consumers"],
      "verify": "python labs/uc05_impact/verify.py"
    },
    "06": {
      "slug": "uc-06-plan-new-feature",
      "title": "Plan a New Feature",
      "branch": "uc-06-plan-new-feature",
      "project_dir": "labs/uc06_feature",
      "start": null,
      "focus_paths": ["demoapp/builders/html.py", "labs/uc06_feature/TASK.md"],
      "verify": "pytest labs/uc06_feature/tests -q"
    },
    "07": {
      "slug": "uc-07-generate-code",
      "title": "Generate Code That Fits",
      "branch": "uc-07-generate-code",
      "project_dir": "labs/uc07_codegen",
      "start": null,
      "focus_paths": ["demoapp/ext/github.py", "labs/uc07_codegen/TASK.md"],
      "verify": "pytest labs/uc07_codegen/tests -q"
    },
    "08": {
      "slug": "uc-08-check-code-logic",
      "title": "Check Code Logic",
      "branch": "uc-08-check-code-logic",
      "project_dir": "labs/uc08_logic",
      "start": null,
      "focus_paths": ["demoapp/builders/html.py"],
      "verify": "python labs/uc08_logic/verify.py"
    },
    "09": {
      "slug": "uc-09-compare-versions",
      "title": "Compare Versions",
      "branch": "uc-09-compare-versions",
      "project_dir": "labs/uc09_compare",
      "start": null,
      "focus_paths": ["demoapp/builders/html.py"],
      "verify": "python labs/uc09_compare/verify.py"
    },
    "10": {
      "slug": "uc-10-quick-check",
      "title": "Quick Check",
      "branch": "uc-10-quick-check",
      "project_dir": "labs/uc10_quick",
      "start": null,
      "focus_paths": ["demoapp/builders/html.py"],
      "verify": "python labs/uc10_quick/verify.py"
    }
  }
}
